{
  "name": "react-xlsx-monorepo",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "build:playground": "pnpm --filter @react-xlsx/playground build",
    "clean": "pnpm -r --filter './packages/*' run clean",
    "dev": "pnpm --filter @react-xlsx/playground dev",
    "typecheck": "pnpm -r --filter './packages/*' run typecheck && pnpm --filter @react-xlsx/playground typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
